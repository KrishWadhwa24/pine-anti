# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TradeNexus Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Server
SERVER_PORT=8080
LOG_LEVEL=info

# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=tradenexus2026

# MongoDB (Docker container on host)
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=tradenexus

# Redis (Docker container on host)
REDIS_ADDR=127.0.0.1:6380
REDIS_PASSWORD=
REDIS_DB=0

# Angel One SmartAPI
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# Telegram defaults (used until a user saves personal settings in the UI)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Encryption (32 bytes hex for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Redis TTL Policies (seconds)
TTL_DEDUP_CACHE=172800
TTL_ACTIVE_CANDLE=7200
TTL_RECOVERY_BUFFER=86400
TTL_WS_SESSION=1800
TTL_REPLAY_STATE=3600

# Strategy Parameters
STRATEGY_BREAKOUT_LOOKBACK=20
STRATEGY_VOLUME_MULTIPLIER=1.8
STRATEGY_COOLDOWN_BARS=12

# Warmup Sizes
WARMUP_1H=500
WARMUP_4H=300
WARMUP_1D=250
WARMUP_1W=120
WARMUP_1M=60
